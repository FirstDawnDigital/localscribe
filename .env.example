# HuggingFace token for pyannote diarization models.
# Required: create at https://huggingface.co/settings/tokens (read scope)
# Also: accept license at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=

# Ollama model used for summarization. Must be pulled first: `ollama pull <name>`
# Default: gemma4:12b-mlx (Apple Silicon optimized, 256K context, best multilingual)
# Alternatives: gemma4:e4b (smaller/faster), gemma3:12b (no MLX), gemma2:9b (legacy, 8K context)
OLLAMA_MODEL=gemma4:12b-mlx
OLLAMA_URL=http://localhost:11434

# Whisper model size: tiny | base | small | medium | large-v3
# large-v3 = best quality, slowest. medium = faster, good for English.
WHISPER_MODEL=large-v3

# Compute device for WhisperX. On Apple Silicon use "cpu" with int8.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
