# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.python-version-cache

# uv
.uv-cache/

# Local secrets
.env

# Generated outputs
output/

# Audio input (interviews, voice memos, test recordings — never commit)
input/
*.mp3
*.wav
*.m4a
*.flac
*.ogg

# Hand-curated reference transcripts (verbatim content of real recordings → PII)
references/

# Local archive for private artifacts kept on disk but never committed
# (intermediate exports, hand-edited drafts, audit logs, etc.)
archive/

# Vendored binary tooling (e.g. deep-filter releases) — fetch locally, do not commit
.tools/

# Ad-hoc test scripts that may contain references to private audio paths
scripts/

# speechbrain creates a literal `None/` symlink cache when `savedir=None`
# is passed — pyannote/PixIT triggers this on first load. Harmless symlinks
# into the HF cache, but should never be committed.
None/

# OS
.DS_Store

# Editor
.vscode/
.idea/
